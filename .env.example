# Copia questo file in .env e inserisci le tue chiavi API.
# .env NON viene committato (vedi .gitignore).

# Chiave Groq per la trascrizione Whisper (obbligatoria)
GROQ_API_KEY=

# GitHub Copilot SDK usa l'autenticazione Copilot/GitHub disponibile in ambiente.
# Se necessario, valorizzare uno di questi token.
COPILOT_GITHUB_TOKEN=
GITHUB_TOKEN=
